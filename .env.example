# ==========================================================================
# Ambiente base do Data Lake — copie este arquivo para `.env` e ajuste.
#   cp .env.example .env
# O arquivo `.env` é lido automaticamente pelo docker-compose e NÃO deve
# ser versionado (já está no .gitignore).
#
# ⚠️  As credenciais abaixo servem APENAS para desenvolvimento local.
#     Troque por senhas fortes e aleatórias antes de qualquer uso
#     compartilhado ou em produção.
# ==========================================================================

# --- PostgreSQL (banco de origem) ---
POSTGRES_USER=olist
POSTGRES_PASSWORD=olist_pwd
POSTGRES_DB=olist_source
# Porta no host (a 5432/5433 costumam estar ocupadas por Postgres locais; usamos 5434).
POSTGRES_PORT=5434

# --- MinIO (object storage / Data Lake) ---
# Atenção: MINIO_ROOT_PASSWORD precisa ter no mínimo 8 caracteres.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Data Lake ---
# Bucket inicial criado automaticamente no startup.
DATALAKE_BUCKET=datalake

# --- Airflow (orquestração — profile "airflow") ---
AIRFLOW_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Gere com:
#   docker run --rm apache/airflow:2.10.5-python3.11 \
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# --- Origem dos dados (Supabase / PostgreSQL) ---
# A origem REAL dos dados é o Supabase (o PostgreSQL local acima é apenas o
# banco de metadados do Airflow). Preencha no seu .env (NÃO commitar).
#
# ⚠️  O painel do Supabase mudou: a connection string fica no botão verde
#     "Connect" (topo do dashboard), não mais em Settings → Database.
#     Lá aparecem 3 opções: Direct connection, Transaction pooler e
#     Session pooler.
#
#     USE O "SESSION POOLER" (porta 5432). Motivos:
#       - a conexão direta (db.<ref>.supabase.co) hoje só resolve em IPv6,
#         e os containers Docker saem por IPv4 → daria timeout no pipeline;
#       - o pooler (aws-1-<regiao>.pooler.supabase.com) resolve em IPv4.
#     Atenção: no pooler o usuário vem como `postgres.<project-ref>`
#     (e não apenas `postgres`).
#
# Exemplo de string do Session pooler:
#   postgresql://postgres.SEU-REF:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
SOURCE_DB_HOST=aws-1-sa-east-1.pooler.supabase.com
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=postgres
SOURCE_DB_USER=postgres.SEU-PROJECT-REF
SOURCE_DB_PASSWORD=
SOURCE_DB_SCHEMA=source
