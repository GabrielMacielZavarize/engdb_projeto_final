# ==========================================================================
# Ambiente base do Data Lake — copie este arquivo para `.env` e ajuste.
#   cp .env.example .env
# O arquivo `.env` é lido automaticamente pelo docker-compose e NÃO deve
# ser versionado (já está no .gitignore).
#
# ⚠️  As credenciais abaixo servem APENAS para desenvolvimento local.
#     Troque por senhas fortes e aleatórias antes de qualquer uso
#     compartilhado ou em produção.
# ==========================================================================

# --- PostgreSQL (banco de origem) ---
POSTGRES_USER=olist
POSTGRES_PASSWORD=olist_pwd
POSTGRES_DB=olist_source
# Porta no host (a 5432/5433 costumam estar ocupadas por Postgres locais; usamos 5434).
POSTGRES_PORT=5434

# --- MinIO (object storage / Data Lake) ---
# Atenção: MINIO_ROOT_PASSWORD precisa ter no mínimo 8 caracteres.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Data Lake ---
# Bucket inicial criado automaticamente no startup.
DATALAKE_BUCKET=datalake
